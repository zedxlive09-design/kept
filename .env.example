# Kept — Environment Variables (§15 of kept-master-architecture.md)
#
# Copy this file to .env.local and fill in your Supabase credentials.
# Get them from: https://supabase.com/dashboard → Your Project → Settings → API
#
# Public — safe to expose. RLS protects data, not key secrecy. (§11, §15)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The following secrets are ONLY used in Supabase Edge Functions.
# Set them via the Supabase CLI, NOT in this file:
#   supabase secrets set GEMINI_API_KEY=...
#   supabase secrets set RESEND_API_KEY=...
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
#
# NEVER add them as NEXT_PUBLIC_* variables. (§7, §10, §11, §15)